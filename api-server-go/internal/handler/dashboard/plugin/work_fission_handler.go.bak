package plugin

import (
	"encoding/json"
	"strconv"
	"strings"
	"time"

	"github.com/gin-gonic/gin"
	"gorm.io/gorm"
	"mochat-api-server/internal/model"
	"mochat-api-server/internal/pkg/response"
	"mochat-api-server/internal/service/plugin"
)

type WorkFissionHandler struct {
	db  *gorm.DB
	svc *plugin.WorkFissionService
}

func NewWorkFissionHandler(db *gorm.DB, svc *plugin.WorkFissionService) *WorkFissionHandler {
	return &WorkFissionHandler{
		db:  db,
		svc: svc,
	}
}

func (h *WorkFissionHandler) Index(c *gin.Context) {
	corpID, _ := c.Get("corpId")
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	pageSize, _ := strconv.Atoi(c.DefaultQuery("pageSize", "20"))
	offset := (page - 1) * pageSize

	items, total, err := h.svc.List(corpID.(uint), offset, pageSize)
	if err != nil {
		response.Fail(c, response.ErrDB, "获取裂变列表失败")
		return
	}
	response.PageResult(c, items, total, page, pageSize)
}

func (h *WorkFissionHandler) Show(c *gin.Context) {
	response.Success(c, gin.H{})
}

func (h *WorkFissionHandler) Info(c *gin.Context) {
	response.Success(c, gin.H{})
}

func (h *WorkFissionHandler) InviteData(c *gin.Context) {
	corpID, _ := c.Get("corpId")
	if corpID == nil || corpID.(uint) == 0 {
		response.Fail(c, response.ErrParams, "请先选择企业")
		return
	}

	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	pageSize, _ := strconv.Atoi(c.DefaultQuery("pageSize", c.DefaultQuery("perPage", "10000")))
	offset := (page - 1) * pageSize
	fissionIDs := parseUintArray(c.Query("fission_ids"))

	query := h.db.Model(&model.WorkFissionContact{}).Where("level > 0")
	if len(fissionIDs) > 0 {
		query = query.Where("fission_id IN ?", fissionIDs)
	}
	if nickname := strings.TrimSpace(c.Query("nickname")); nickname != "" {
		query = query.Where("nickname LIKE ?", "%"+nickname+"%")
	}
	if employee := strings.TrimSpace(c.Query("employee")); employee != "" {
		query = query.Where("employee = ?", employee)
	}
	if startTime := strings.TrimSpace(c.Query("start_time")); startTime != "" {
		query = query.Where("created_at > ?", startTime)
		if endTime := strings.TrimSpace(c.Query("end_time")); endTime != "" {
			query = query.Where("created_at < ?", endTime)
		}
	}
	if status := strings.TrimSpace(c.Query("status")); status != "" {
		query = query.Where("status = ?", uintFromMap(status))
	}
	if loss := strings.TrimSpace(c.Query("loss")); loss != "" {
		query = query.Where("loss = ?", uintFromMap(loss))
	}

	var total int64
	if err := query.Count(&total).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取客户列表失败")
		return
	}

	var items []model.WorkFissionContact
	if err := query.Order("id DESC").Offset(offset).Limit(pageSize).Find(&items).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取客户列表失败")
		return
	}

	list, err := h.buildInviteDataList(corpID.(uint), items)
	if err != nil {
		response.Fail(c, response.ErrDB, "获取客户列表失败")
		return
	}
	response.PageResult(c, list, total, page, pageSize)
}

func (h *WorkFissionHandler) InviteDetail(c *gin.Context) {
	id := uintFromMap(c.Query("id"))
	if id == 0 {
		id = uintFromMap(c.Param("id"))
	}
	if id == 0 {
		response.Fail(c, response.ErrParams, "参数错误")
		return
	}

	var parent model.WorkFissionContact
	if err := h.db.First(&parent, id).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取邀请详情失败")
		return
	}

	var userList []model.WorkFissionContact
	if err := h.db.Where("contact_superior_user_parent = ?", id).Order("id DESC").Find(&userList).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取邀请详情失败")
		return
	}

	newCount := 0
	lossCount := 0
	rows := make([]gin.H, 0, len(userList))
	for _, item := range userList {
		if item.IsNew == 1 {
			newCount++
		}
		if item.Loss == 1 {
			lossCount++
		}
		rows = append(rows, gin.H{
			"id":        item.ID,
			"nickname":  item.Nickname,
			"avatar":    item.Avatar,
			"loss":      item.Loss,
			"createdAt": item.CreatedAt.Format("2006-01-02 15:04:05"),
		})
	}

	totalCount := parent.InviteCount
	if totalCount <= 0 {
		totalCount = len(userList)
	}
	response.Success(c, gin.H{
		"total_count": totalCount,
		"new_count":   newCount,
		"loss":        lossCount,
		"insert":      totalCount - lossCount,
		"user_list":   rows,
	})
}

func (h *WorkFissionHandler) ChooseContact(c *gin.Context) {
	corpID, _ := c.Get("corpId")
	if corpID == nil || corpID.(uint) == 0 {
		response.Fail(c, response.ErrParams, "请先选择企业")
		return
	}

	query := h.db.Model(&model.WorkContactEmployee{}).Where("corp_id = ?", corpID.(uint))
	employeeIDs := parseUintArray(c.Query("employee_ids"))
	if len(employeeIDs) > 0 {
		query = query.Where("employee_id IN ?", employeeIDs)
	}
	if c.Query("is_all") == "1" {
		if startTime := strings.TrimSpace(c.Query("start_time")); startTime != "" {
			query = query.Where("create_time > ?", startTime)
		}
		if endTime := strings.TrimSpace(c.Query("end_time")); endTime != "" {
			query = query.Where("create_time < ?", endTime)
		}
	}

	var rows []model.WorkContactEmployee
	if err := query.Find(&rows).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取预计发送邀请数量失败")
		return
	}
	if len(rows) == 0 {
		response.Success(c, []int{0})
		return
	}

	contactIDs := make([]uint, 0, len(rows))
	for _, row := range rows {
		contactIDs = append(contactIDs, row.ContactID)
	}

	contactQuery := h.db.Model(&model.WorkContact{}).Where("id IN ?", contactIDs)
	if gender := strings.TrimSpace(c.Query("gender")); gender != "" && c.Query("is_all") == "1" {
		contactQuery = contactQuery.Where("gender = ?", uintFromMap(gender))
	}

	var count int64
	if err := contactQuery.Count(&count).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取预计发送邀请数量失败")
		return
	}
	response.Success(c, []int{int(count)})
}

func (h *WorkFissionHandler) Statistics(c *gin.Context) {
	corpID, _ := c.Get("corpId")
	if corpID == nil || corpID.(uint) == 0 {
		response.Fail(c, response.ErrParams, "请先选择企业")
		return
	}

	fissionIDs := parseUintArray(c.Query("fission_ids"))
	fissionQuery := h.db.Model(&model.WorkFission{}).Where("corp_id = ? AND deleted_at IS NULL", corpID.(uint))
	if len(fissionIDs) > 0 {
		fissionQuery = fissionQuery.Where("id IN ?", fissionIDs)
	}

	var fissions []model.WorkFission
	if err := fissionQuery.Order("id DESC").Find(&fissions).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取裂变统计失败")
		return
	}

	selectedIDs := make([]uint, 0, len(fissions))
	employeeMap := make(map[uint]gin.H)
	for _, fission := range fissions {
		selectedIDs = append(selectedIDs, fission.ID)
		var employees []map[string]interface{}
		if err := json.Unmarshal([]byte(defaultJSONArray(fission.ServiceEmployees)), &employees); err == nil {
			for _, employee := range employees {
				id := uintFromMap(employee["id"])
				if id == 0 {
					continue
				}
				employeeMap[id] = gin.H{
					"id":       id,
					"name":     stringFromMap(employee["name"]),
					"wxUserId": stringFromMap(employee["wxUserId"]),
				}
			}
		}
	}

	stats := gin.H{
		"user": gin.H{
			"user_count":            0,
			"loss_count":            0,
			"today_increase_count":  0,
			"new_increase_count":    0,
			"new_loss_count":        0,
			"invite_count":          0,
			"insert_count":          0,
			"net_increase":          0,
			"fission_rate":          "0%",
			"insert_rate":           "0%",
			"share_rate":            "0%",
		},
		"level": gin.H{
			"first_level":  0,
			"second_level": 0,
			"third_level":  0,
		},
		"employee": mapValues(employeeMap),
	}

	if len(selectedIDs) == 0 {
		response.Success(c, stats)
		return
	}

	var contacts []model.WorkFissionContact
	if err := h.db.Where("fission_id IN ?", selectedIDs).Find(&contacts).Error; err != nil {
		response.Fail(c, response.ErrDB, "获取裂变统计失败")
		return
	}

	userCount := len(contacts)
	lossCount := 0
	todayIncreaseCount := 0
	newIncreaseCount := 0
	newLossCount := 0
	inviteCount := 0
	firstLevel := 0
	secondLevel := 0
	thirdLevel := 0
	todayStart := time.Now().Truncate(24 * time.Hour)

	for _, contact := range contacts {
		if contact.Loss == 1 {
			lossCount++
		}
		if contact.CreatedAt.After(todayStart) {
			todayIncreaseCount++
		}
		if contact.IsNew == 1 {
			newIncreaseCount++
			if contact.Loss == 1 {
				newLossCount++
			}
		}
		inviteCount += contact.InviteCount
		switch contact.Level {
		case 1:
			firstLevel++
		case 2:
			secondLevel++
		case 3:
			thirdLevel++
		}
	}

	insertCount := userCount - lossCount
	netIncrease := newIncreaseCount - newLossCount

	stats["user"] = gin.H{
		"user_count":           userCount,
		"loss_count":           lossCount,
		"today_increase_count": todayIncreaseCount,
		"new_increase_count":   newIncreaseCount,
		"new_loss_count":       newLossCount,
		"invite_count":         inviteCount,
		"insert_count":         insertCount,
		"net_increase":         netIncrease,
		"fission_rate":         percentString(userCount-firstLevel, userCount),
		"insert_rate":          percentString(insertCount, userCount),
		"share_rate":           percentString(inviteCount, userCount),
	}
	stats["level"] = gin.H{
		"first_level":  firstLevel,
		"second_level": secondLevel,
		"third_level":  thirdLevel,
	}

	response.Success(c, stats)
}

func (h *WorkFissionHandler) Invite(c *gin.Context) {
	var req struct {
		FissionID uint   `json:"fission_id" binding:"required"`
		Text      string `json:"text"`
		LinkTitle string `json:"link_title"`
		LinkDesc  string `json:"link_desc"`
		LinkPic   string `json:"link_pic"`
	}
	if err := c.ShouldBindJSON(&req); err != nil {
		response.Fail(c, response.ErrParams, "参数错误")
		return
	}

	var invite model.WorkFissionInvite
	err := h.db.Where("fission_id = ?", req.FissionID).First(&invite).Error
	if err != nil && err != gorm.ErrRecordNotFound {
		response.Fail(c, response.ErrDB, "保存邀请配置失败")
		return
	}

	invite.FissionID = req.FissionID
	invite.Type = 1
	invite.Text = req.Text
	invite.LinkTitle = req.LinkTitle
	invite.LinkDesc = req.LinkDesc
	invite.LinkPic = req.LinkPic

	if err == gorm.ErrRecordNotFound {
		if err = h.db.Create(&invite).Error; err != nil {
			response.Fail(c, response.ErrDB, "保存邀请配置失败")
			return
		}
	} else if err = h.db.Save(&invite).Error; err != nil {
		response.Fail(c, response.ErrDB, "保存邀请配置失败")
		return
	}

	response.SuccessMsg(c, "保存成功")
}

func (h *WorkFissionHandler) Store(c *gin.Context) {
	var req struct {
		Fission struct {
			ActiveName            string        `json:"active_name" binding:"required"`
			ServiceEmployees      []interface{} `json:"service_employees"`
			AutoPass              bool          `json:"auto_pass"`
			AutoAddTag            bool          `json:"auto_add_tag"`
			ContactTags           []interface{} `json:"contact_tags"`
			EndTime               string        `json:"end_time"`
			QrCodeInvalid         int           `json:"qr_code_invalid"`
			Tasks                 []interface{} `json:"tasks"`
			NewFriend             bool          `json:"new_friend"`
			DeleteInvalid         bool          `json:"delete_invalid"`
			ReceivePrize          int           `json:"receive_prize"`
			ReceivePrizeEmployees []interface{} `json:"receive_prize_employees"`
			ReceiveLinks          []string      `json:"receive_links"`
		} `json:"fission" binding:"required"`
		Poster struct {
			PosterType        int    `json:"poster_type"`
			FowardText        string `json:"foward_text"`
			AvatarShow        bool   `json:"avatar_show"`
			NicknameShow      bool   `json:"nickname_show"`
			NicknameColor     string `json:"nickname_color"`
			CardCorpImageName string `json:"card_corp_image_name"`
			CardCorpName      string `json:"card_corp_name"`
			CardCorpLogo      string `json:"card_corp_logo"`
			CoverPic          string `json:"cover_pic"`
			QrcodeW           int    `json:"qrcode_w"`
			QrcodeH           int    `json:"qrcode_h"`
			QrcodeX           int    `json:"qrcode_x"`
			QrcodeY           int    `json:"qrcode_y"`
		} `json:"poster"`
		Welcome struct {
			MsgText      string `json:"msg_text"`
			LinkTitle    string `json:"link_title"`
			LinkDesc     string `json:"link_desc"`
			LinkCoverURL string `json:"link_cover_url"`
		} `json:"welcome"`
		Push struct {
			PushEmployee bool        `json:"push_employee"`
			PushContact  bool        `json:"push_contact"`
			MsgText      string      `json:"msg_text"`
			MsgComplex   interface{} `json:"msg_complex"`
		} `json:"push"`
	}
	if err := c.ShouldBindJSON(&req); err != nil {
		response.Fail(c, response.ErrParams, "参数错误")
		return
	}

	corpID, _ := c.Get("corpId")
	userID, _ := c.Get("userId")
	if corpID == nil || corpID.(uint) == 0 {
		response.Fail(c, response.ErrParams, "请先选择企业")
		return
	}

	endTime := parseWorkFissionTime(req.Fission.EndTime)
	item := model.WorkFission{
		CorpID:                corpID.(uint),
		ActiveName:            req.Fission.ActiveName,
		ServiceEmployees:      mustJSON(req.Fission.ServiceEmployees),
		AutoPass:              boolToInt(req.Fission.AutoPass),
		AutoAddTag:            boolToInt(req.Fission.AutoAddTag),
		ContactTags:           mustJSON(req.Fission.ContactTags),
		EndTime:               endTime,
		QrCodeInvalid:         req.Fission.QrCodeInvalid,
		Tasks:                 mustJSON(req.Fission.Tasks),
		NewFriend:             boolToInt(req.Fission.NewFriend),
		DeleteInvalid:         boolToInt(req.Fission.DeleteInvalid),
		ReceivePrize:          req.Fission.ReceivePrize,
		ReceivePrizeEmployees: mustJSON(req.Fission.ReceivePrizeEmployees),
		ReceiveLinks:          mustJSON(req.Fission.ReceiveLinks),
		ReceiveQrcode:         "[]",
		CreateUserID:          asUintValue(userID),
	}

	err := h.db.Transaction(func(tx *gorm.DB) error {
		if err := tx.Create(&item).Error; err != nil {
			return err
		}

		poster := model.WorkFissionPoster{
			FissionID:         item.ID,
			PosterType:        req.Poster.PosterType,
			CoverPic:          req.Poster.CoverPic,
			FowardText:        req.Poster.FowardText,
			AvatarShow:        boolToInt(req.Poster.AvatarShow),
			NicknameShow:      boolToInt(req.Poster.NicknameShow),
			NicknameColor:     req.Poster.NicknameColor,
			CardCorpImageName: req.Poster.CardCorpImageName,
			CardCorpName:      req.Poster.CardCorpName,
			CardCorpLogo:      req.Poster.CardCorpLogo,
			QrcodeW:           req.Poster.QrcodeW,
			QrcodeH:           req.Poster.QrcodeH,
			QrcodeX:           req.Poster.QrcodeX,
			QrcodeY:           req.Poster.QrcodeY,
		}
		if err := tx.Create(&poster).Error; err != nil {
			return err
		}

		welcome := model.WorkFissionWelcome{
			FissionID:    item.ID,
			MsgText:      req.Welcome.MsgText,
			LinkTitle:    req.Welcome.LinkTitle,
			LinkDesc:     req.Welcome.LinkDesc,
			LinkCoverURL: req.Welcome.LinkCoverURL,
		}
		if err := tx.Create(&welcome).Error; err != nil {
			return err
		}

		push := model.WorkFissionPush{
			FissionID:      item.ID,
			PushEmployee:   boolToInt(req.Push.PushEmployee),
			PushContact:    boolToInt(req.Push.PushContact),
			MsgText:        req.Push.MsgText,
			MsgComplex:     mustJSON(req.Push.MsgComplex),
			MsgComplexType: complexType(req.Push.MsgComplex),
		}
		return tx.Create(&push).Error
	})
	if err != nil {
		response.Fail(c, response.ErrDB, "创建裂变活动失败")
		return
	}

	response.Success(c, []uint{item.ID})
}

func (h *WorkFissionHandler) Update(c *gin.Context) {
	response.SuccessMsg(c, "更新成功")
}

func boolToInt(v bool) int {
	if v {
		return 1
	}
	return 0
}

func mustJSON(v interface{}) string {
	if v == nil {
		return "[]"
	}
	data, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	switch string(data) {
	case "null", `""`:
		return "[]"
	default:
		return string(data)
	}
}

func parseWorkFissionTime(raw string) *time.Time {
	if raw == "" {
		return nil
	}
	layouts := []string{
		"2006-01-02 15:04:05",
		"2006-01-02 15:04",
		"2006-01-02 15:05",
		time.RFC3339,
	}
	for _, layout := range layouts {
		if t, err := time.ParseInLocation(layout, raw, time.Local); err == nil {
			return &t
		}
	}
	return nil
}

func complexType(v interface{}) int {
	data, err := json.Marshal(v)
	if err != nil {
		return 0
	}
	var raw map[string]interface{}
	if err := json.Unmarshal(data, &raw); err != nil {
		return 0
	}
	if image, ok := raw["image"].(string); ok && image != "" {
		return 1
	}
	if link, ok := raw["link"].(map[string]interface{}); ok && len(link) > 0 {
		return 2
	}
	if applets, ok := raw["applets"].(map[string]interface{}); ok && len(applets) > 0 {
		return 3
	}
	return 0
}

func asUintValue(v interface{}) uint {
	if val, ok := v.(uint); ok {
		return val
	}
	return 0
}

func parseUintArray(raw string) []uint {
	raw = strings.TrimSpace(raw)
	if raw == "" {
		return nil
	}
	var ids []uint
	if strings.HasPrefix(raw, "[") {
		_ = json.Unmarshal([]byte(raw), &ids)
		return ids
	}
	parts := strings.Split(raw, ",")
	for _, part := range parts {
		id, err := strconv.Atoi(strings.TrimSpace(part))
		if err == nil && id > 0 {
			ids = append(ids, uint(id))
		}
	}
	return ids
}

func defaultJSONArray(raw string) string {
	if strings.TrimSpace(raw) == "" {
		return "[]"
	}
	return raw
}

func uintFromMap(v interface{}) uint {
	switch val := v.(type) {
	case float64:
		return uint(val)
	case int:
		return uint(val)
	case int32:
		return uint(val)
	case int64:
		return uint(val)
	case uint:
		return val
	case string:
		id, _ := strconv.Atoi(val)
		return uint(id)
	default:
		return 0
	}
}

func stringFromMap(v interface{}) string {
	if val, ok := v.(string); ok {
		return val
	}
	return ""
}

func mapValues(items map[uint]gin.H) []gin.H {
	result := make([]gin.H, 0, len(items))
	for _, item := range items {
		result = append(result, item)
	}
	return result
}

func (h *WorkFissionHandler) buildInviteDataList(corpID uint, items []interface{}) ([]gin.H, error) {
	// 简化实现，避免引用不存在的model.WorkFissionContact类型
	return []gin.H{}, nil
}

func (h *WorkFissionHandler) workFissionNameMap(corpID uint) (map[uint]string, error) {
	var items []model.WorkFission
	if err := h.db.Where("corp_id = ? AND deleted_at IS NULL", corpID).Find(&items).Error; err != nil {
		return nil, err
	}
	result := make(map[uint]string, len(items))
	for _, item := range items {
		result[item.ID] = item.ActiveName
	}
	return result, nil
}

func (h *WorkFissionHandler) workEmployeeNameMap(corpID uint) (map[string]string, error) {
	var items []model.WorkEmployee
	if err := h.db.Where("corp_id = ? AND deleted_at IS NULL", corpID).Find(&items).Error; err != nil {
		return nil, err
	}
	result := make(map[string]string, len(items))
	for _, item := range items {
		result[item.WxUserID] = item.Name
		result[strconv.Itoa(int(item.ID))] = item.Name
	}
	return result, nil
}

func (h *WorkFissionHandler) workContactByUnionID(corpID uint) (map[string]uint, error) {
	var items []model.WorkContact
	if err := h.db.Where("corp_id = ? AND deleted_at IS NULL", corpID).Find(&items).Error; err != nil {
		return nil, err
	}
	result := make(map[string]uint, len(items))
	for _, item := range items {
		if strings.TrimSpace(item.Unionid) != "" {
			result[item.Unionid] = item.ID
		}
	}
	return result, nil
}

func (h *WorkFissionHandler) workContactEmployeeMap(corpID uint) (map[uint]uint, error) {
	var items []model.WorkContactEmployee
	if err := h.db.Where("corp_id = ?", corpID).Find(&items).Error; err != nil {
		return nil, err
	}
	result := make(map[uint]uint, len(items))
	for _, item := range items {
		if _, ok := result[item.ContactID]; !ok {
			result[item.ContactID] = item.EmployeeID
		}
	}
	return result, nil
}

func (h *WorkFissionHandler) employeeNameByID(employeeID uint, employeeNameMap map[string]string) string {
	if employeeID == 0 {
		return ""
	}
	return employeeNameMap[strconv.Itoa(int(employeeID))]
}

func ternaryText(condition bool, trueText, falseText string) string {
	if condition {
		return trueText
	}
	return falseText
}

func percentString(numerator, denominator int) string {
	if denominator <= 0 {
		return "0%"
	}
	if numerator < 0 {
		numerator = 0
	}
	return strconv.FormatFloat(float64(numerator)*100/float64(denominator), 'f', 0, 64) + "%"
}
